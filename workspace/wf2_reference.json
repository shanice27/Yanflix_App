                  {
                      "parameters":  {
                                         "jsCode":  "const GEMINI_KEY = process.env.GEMINI_API_KEY || \"AIzaSyAoEVR6qxgYlvB_n-ZKLlvUQUN6ggxqjnU\";\nconst OLLAMA_URL = \"http://host.docker.internal:11434\";\nconst MODELS = [\n  { type: \"gemini\", id: \"gemini-2.5-flash\" },\n  { type: \"gemini\", id: \"gemini-2.0-flash\" },\n  { type: \"gemini\", id: \"gemini-2.0-flash-lite\" },\n  { type: \"gemini\", id: \"gemini-2.5-flash-lite\" },\n  { type: \"ollama\", id: \"llama3.1:8b\" },\n];\nconst WAITS_MS = [0, 30000, 47000, 60000, 60000];\nconst body = $input.first().json.body || $input.first().json;\nconst system_prompt = body.system_prompt || \"\";\nconst segments = body.segments || [];\nconst ep_folder = body.ep_folder || \"\";\nconst prompt = system_prompt + \"\n\nSegments to translate:\n\" + JSON.stringify(segments, null, 2);\nasync function sleep(ms) { return new Promise(r =\u003e setTimeout(r, ms)); }\nlet lastError = null;\nfor (let i = 0; i \u003c MODELS.length; i++) {\n  const model = MODELS[i];\n  const delay = WAITS_MS[i] || 0;\n  if (delay \u003e 0) await sleep(delay);\n  if (model.type === \"ollama\") {\n    try {\n      const lc = await this.helpers.httpRequest({ method: \"GET\", url: \"http://host.docker.internal:3000/api/gpu-status\", json: true });\n      if (lc.locked) { lastError = new Error(\"GPU lock held\"); continue; }\n    } catch (_) {}\n  }\n  try {\n    let result;\n    if (model.type === \"gemini\") {\n      result = await this.helpers.httpRequest({ method: \"POST\", url: `https://generativelanguage.googleapis.com/v1beta/models/${model.id}:generateContent`, headers: { \"x-goog-api-key\": GEMINI_KEY, \"Content-Type\": \"application/json\" }, body: { contents: [{ parts: [{ text: prompt }] }], generationConfig: { responseMimeType: \"application/json\" } }, json: true });\n      const text = result.candidates?.[0]?.content?.parts?.[0]?.text;\n      if (!text) throw new Error(\"Empty response from \" + model.id);\n      return [{ json: { model_used: model.id, ep_folder, state: JSON.parse(text) } }];\n    } else {\n      result = await this.helpers.httpRequest({ method: \"POST\", url: `${OLLAMA_URL}/api/generate`, headers: { \"Content-Type\": \"application/json\" }, body: { model: model.id, prompt, stream: false, format: \"json\" }, json: true });\n      const text = result.response;\n      if (!text) throw new Error(\"Empty response from Ollama\");\n      return [{ json: { model_used: model.id, ep_folder, state: JSON.parse(text) } }];\n    }\n  } catch (err) { lastError = err; continue; }\n}\nthrow new Error(\"All models exhausted. Last error: \" + (lastError?.message || \"unknown\"));"
                                     },
